# Where the SDK ships telemetry (local dev harness by default)
INDRATRACE_ENDPOINT=http://localhost:4318
# API key (harness doesn't verify; real keys come from the platform registry).
# INDRATRACE_KEY is the deprecated pre-0.5.0 name — still honored, but warns.
INDRATRACE_API_KEY=dev-local

# Diagnostics: 1/true/yes/on prints a startup banner + audible export outcomes.
# Off by default; turn on when nothing shows up and you want to see why.
# INDRATRACE_DEBUG=1

# Only needed for GenAI integration tests (task 04)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
